{"cells":[{"cell_type":"code","execution_count":null,"metadata":{"collapsed":true,"id":"BZx96kENZann"},"outputs":[],"source":["# Install the IPython SQL extension to allow SQL queries inside Colab cells\n","!pip install ipython-sql\n","\n","# Load the SQL extension into the Colab environment execution memory\n","%load_ext sql\n","\n","# Create and connect to a localized database file named 'enterprise_portfolio.db'\n","%sql sqlite:///enterprise_portfolio.db"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"-KFSG74Sh9PD"},"outputs":[],"source":["\n","import os\n","import zipfile\n","import shutil\n","import sqlite3\n","import pandas as pd\n","from google.colab import drive\n","#MOUNT PERMANENT GOOGLE DRIVE STORAGE\n","print(\"--- Connecting to your permanent Google Drive... ---\")\n","drive.mount('/content/drive')\n","\n","# Establish the exact permanent storage folder paths\n","destination_dir = '/content/drive/MyDrive/LendingClub_Project'\n","os.makedirs(destination_dir, exist_ok=True)\n","permanent_db_path = os.path.join(destination_dir, 'enterprise_portfolio.db')\n","#AUTOMATED KAGGLE AUTHENTICATION CONFIGURATION\n","print(\"--- Configuring your Kaggle API Token... ---\")\n","os.makedirs('/root/.kaggle', exist_ok=True)\n","\n","# Directly writing your new API credential token into the system environment\n","kaggle_token = '{\"username\":\"evansmwandiki\",\"key\":\"469694bef527f134ca45ce85ef2bfc03\"}'\n","\n","with open('/root/.kaggle/kaggle.json', 'w') as f:\n","    f.write(kaggle_token)\n","os.chmod('/root/.kaggle/kaggle.json', 600)\n","print(\"--- Kaggle Credentials Successfully Validated! ---\")\n","\n","#SET YOUR DYNAMIC DATASET IDENTIFIER\n","# FLEXIBLE DESIGN: To download insurance or derivative instruments later,\n","# simply swap this string out with the dataset's username/repository name!\n","dataset_id = \"wordsforthewise/lending-club\"\n","\n","print(f\"\\n--- Triggering Kaggle download for: {dataset_id} ---\")\n","!kaggle datasets download -d {dataset_id}\n","#EXTRACT DATA TO ULTRA-FAST LOCAL DISK\n","zip_file_name = dataset_id.split('/')[-1] + \".zip\"\n","print(f\"--- Extracting archive locally: {zip_file_name} ---\")\n","\n","with zipfile.ZipFile(zip_file_name, 'r') as zip_ref:\n","    zip_ref.extractall('/content/raw_data')\n","    extracted_files = zip_ref.namelist()\n","\n","raw_csv_path = f\"/content/raw_data/{extracted_files[0]}\"\n","local_cache_db = \"/content/local_cache.db\"\n","\n","# Clear out any stale local database files before starting the fresh build\n","if os.path.exists(local_cache_db):\n","    os.remove(local_cache_db)\n","\n","#CHUNKED CLEANING & INDEPENDENT SQL CONVERSION\n","print(\"\\n--- Rebuilding clean database structure locally to prevent network locks... ---\")\n","local_conn = sqlite3.connect(local_cache_db)\n","\n","total_raw_rows = 0\n","total_clean_rows = 0\n","chunk_size = 100000\n","\n","# Stream data in blocks of 100,000 rows to optimize performance\n","for i, chunk in enumerate(pd.read_csv(raw_csv_path, chunksize=chunk_size, low_memory=False)):\n","    total_raw_rows += len(chunk)\n","\n","    # Strip any hidden spaces from columns\n","    chunk.columns = chunk.columns.str.strip()\n","\n","    # Data Cleaning Layer: Remove broken rows missing critical inputs\n","    core_columns = ['loan_status', 'grade', 'loan_amnt', 'int_rate']\n","    available_columns = [col for col in core_columns if col in chunk.columns]\n","\n","    df_clean = chunk.dropna(subset=available_columns)\n","    total_clean_rows += len(df_clean)\n","\n","    # Append the clean block directly into your SQL data warehouse table\n","    df_clean.to_sql('loans_ledger', local_conn, if_exists='append', index=False)\n","    print(f\"Committed sanitized row block {i+1} to SQL ledger...\")\n","\n","# Close connection to lock in the binary file changes\n","local_conn.close()\n","\n","# =====================================================================\n","# STEP 6: ATOMIC TRANSFER TO PERMANENT GOOGLE DRIVE\n","# =====================================================================\n","print(\"\\n--- Migration Phase: Saving polished database file to Google Drive... ---\")\n","shutil.copy2(local_cache_db, permanent_db_path)\n","\n","# STEP 7: PIPELINE PERFORMANCE METRICS\n","rpe = (total_clean_rows / total_raw_rows) * 100\n","print(\"=\"*60)\n","print(\"--- PERMANENT DATA WAREHOUSE DEPLOYED SUCCESSFULLY ---\")\n","print(f\"Total Source Rows Analyzed: {total_raw_rows:,}\")\n","print(f\"Total Sanitized Rows Saved: {total_clean_rows:,}\")\n","print(f\"Row Preservation Efficiency (RPE): {rpe:.2f}%\")\n","print(f\"Permanent Database Safe At: {permanent_db_path}\")\n","print(\"=\"*60)"]},{"cell_type":"code","source":["# --- RETRIEVAL BLOCK ---\n","import os\n","import shutil\n","import sqlite3\n","import pandas as pd\n","from google.colab import drive\n","\n","drive.mount('/content/drive')\n","drive_db = '/content/drive/MyDrive/LendingClub_Project/enterprise_portfolio.db'\n","local_db = '/content/enterprise_portfolio_local.db'\n","\n","if os.path.exists(local_db): os.remove(local_db)\n","shutil.copy2(drive_db, local_db)\n","conn = sqlite3.connect(local_db)\n","print(\"--- Active connection open! ---\")"],"metadata":{"id":"rgmbgwEQNVQy"},"execution_count":null,"outputs":[]},{"cell_type":"code","execution_count":null,"metadata":{"id":"_J-UbPhdkdCu"},"outputs":[],"source":["import os\n","import shutil\n","import sqlite3\n","import pandas as pd\n","from google.colab import drive\n","# 1. AUTOMATED CONNECTION CHECKER\n","local_db = '/content/enterprise_portfolio_local.db'\n","drive_db = '/content/drive/MyDrive/LendingClub_Project/enterprise_portfolio.db'\n","\n","# If the 'conn' variable doesn't exist or is closed, initialize it safely\n","if 'conn' not in locals() or 'conn' not in globals():\n","    print(\"--- Connection missing. Opening pipeline to Google Drive... ---\")\n","    if not os.path.exists('/content/drive/MyDrive'):\n","        drive.mount('/content/drive')\n","\n","    if os.path.exists(drive_db):\n","        if os.path.exists(local_db): os.remove(local_db)\n","        shutil.copy2(drive_db, local_db)\n","        conn = sqlite3.connect(local_db)\n","        print(\"--- Active connection established successfully! ---\")\n","    else:\n","        print(\"❌ ERROR: Cannot find the database file in your Google Drive.\")\n","\n","# 2. RUN THE PREVIEW QUERY\n","print(\"--- Fetching first 10 rows... ---\")\n","query = \"\"\"\n","SELECT * FROM loans_ledger\n","LIMIT 10;\n","\"\"\"\n","\n","df_preview = pd.read_sql_query(query, conn)\n","\n","# Enable horizontal scrolling for wide financial tables\n","pd.set_option('display.max_columns', None)\n","df_preview"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"3zNvoAT3pFDM"},"outputs":[],"source":["#ISOLATING THE 15 CORE ACTUARIAL VARIABLES ---\n","query = \"\"\"\n","SELECT\n","    id,\n","    grade,\n","    sub_grade,\n","    loan_amnt,\n","    funded_amnt,\n","    loan_status,\n","    int_rate,\n","    fico_range_low,\n","    fico_range_high,\n","    total_pymnt,\n","    total_rec_prncp,\n","    total_rec_int,\n","    term,\n","    installment,\n","    annual_inc,\n","    dti\n","FROM loans_ledger\n","LIMIT 10;\n","\"\"\"\n","\n","# Execute the targeted query\n","df_core_preview = pd.read_sql_query(query, conn)\n","\n","# Configure pandas to show all 15 columns side-by-side cleanly\n","pd.set_option('display.max_columns', 15)\n","pd.options.display.float_format = '{:,.2f}'.format\n","\n","df_core_preview"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"IfqIwiqr03ph"},"outputs":[],"source":["#EXECUTE THE MASTER PORTFOLIO RISK & YIELD MATRIX\n","query = \"\"\"\n","SELECT\n","    grade,\n","\n","    -- 1. Count-Based Frequency Metrics\n","    COUNT(*) as total_loan_count,\n","    SUM(CASE WHEN loan_status = 'Charged Off' THEN 1 ELSE 0 END) as default_count,\n","    ROUND(\n","        SUM(CASE WHEN loan_status = 'Charged Off' THEN 1 ELSE 0 END) * 100.0 / COUNT(*),\n","        2\n","    ) as default_rate_by_count_percent,\n","\n","    -- 2. Value-Based Capital Exposure Metrics\n","    ROUND(SUM(loan_amnt),2) as total_funded_capital,\n","    ROUND(SUM(CASE WHEN loan_status = 'Charged Off' THEN loan_amnt ELSE 0 END),2) as total_cash_lost,\n","    ROUND(\n","        SUM(CASE WHEN loan_status = 'Charged Off' THEN loan_amnt ELSE 0 END) * 100.0 / SUM(loan_amnt),\n","        2\n","    ) as PAR_percent,\n","\n","    -- 3. Advanced Intrinsic Risk Metrics\n","    ROUND(\n","        (SUM(CASE WHEN loan_status = 'Charged Off' THEN loan_amnt ELSE 0 END) * 100.0 / SUM(loan_amnt)) -\n","        (SUM(CASE WHEN loan_status = 'Charged Off' THEN 1 ELSE 0 END) * 100.0 / COUNT(*)),\n","        2\n","    ) as intrinsic_risk_divergence,\n","\n","    -- 4. Yield and Profitability Spread Metrics\n","    ROUND(SUM(loan_amnt * int_rate) / SUM(loan_amnt), 2) as weighted_avg_interest_rate_percent,\n","    ROUND(\n","        (SUM(loan_amnt * int_rate) / SUM(loan_amnt)) -\n","        (SUM(CASE WHEN loan_status = 'Charged Off' THEN loan_amnt ELSE 0 END) * 100.0 / SUM(loan_amnt)),\n","        2\n","    ) as risk_adjusted_yield_percent\n","\n","FROM loans_ledger\n","WHERE loan_status IN ('Fully Paid', 'Charged Off')\n","  AND grade IS NOT NULL\n","GROUP BY grade\n","ORDER BY grade ASC;\n","\"\"\"\n","\n","# Execute the query through our fast local pipeline connection\n","df_master_portfolio = pd.read_sql_query(query, conn)\n","\n","# Set rendering preferences to handle large numbers with comma separators automatically\n","pd.options.display.float_format = '{:,.2f}'.format\n","\n","# Output the multi-dimensional analytical matrix\n","df_master_portfolio"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"SP-i9weJCEbr"},"outputs":[],"source":["\n","#FICO RISK STRATIFICATION ENGINE\n","query = \"\"\"\n","SELECT\n","    -- 1. Stratify Raw FICO Scores into Institutional Credit Bands\n","    CASE\n","        WHEN fico_range_low >= 780 THEN '780+ (Super Prime)'\n","        WHEN fico_range_low >= 720 AND fico_range_low < 780 THEN '720-779 (Prime)'\n","        WHEN fico_range_low >= 660 AND fico_range_low < 720 THEN '660-719 (Near Prime)'\n","        WHEN fico_range_low >= 600 AND fico_range_low < 660 THEN '600-659 (Subprime)'\n","        ELSE 'Below 600 (Deep Subprime)'\n","    END as fico_risk_band,\n","\n","    -- 2. Volume Frequency Tallies\n","    COUNT(*) as total_loans_issued,\n","    SUM(CASE WHEN loan_status = 'Charged Off' THEN 1 ELSE 0 END) as total_default_count,\n","\n","    -- 3. Frequency-Based Loss Rate\n","    ROUND(\n","        SUM(CASE WHEN loan_status = 'Charged Off' THEN 1 ELSE 0 END) * 100.0 / COUNT(*),\n","        2\n","    ) as default_rate_by_count_percent,\n","\n","    -- 4. Capital Volume Exposure & Gross Write-Offs\n","    CAST(SUM(loan_amnt) AS INT) as total_capital_exposed,\n","    CAST(SUM(CASE WHEN loan_status = 'Charged Off' THEN loan_amnt ELSE 0 END) AS INT) as capital_lost_to_default,\n","\n","    -- 5. Value-Based Portfolio at Risk (PAR %)\n","    ROUND(\n","        SUM(CASE WHEN loan_status = 'Charged Off' THEN loan_amnt ELSE 0 END) * 100.0 / SUM(loan_amnt),\n","        2\n","    ) as portfolio_at_risk_percent\n","\n","FROM loans_ledger\n","WHERE loan_status IN ('Fully Paid', 'Charged Off')\n","  AND fico_range_low IS NOT NULL\n","GROUP BY 1\n","ORDER BY MIN(fico_range_low) DESC;\n","\"\"\"\n","\n","# Execute the stratification query\n","df_fico_stratification = pd.read_sql_query(query, conn)\n","\n","# Format display metrics with clean comma separators\n","pd.options.display.float_format = '{:,.2f}'.format\n","\n","# Output the matrix\n","df_fico_stratification"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"nlBf9xh13AFg"},"outputs":[],"source":["#Loss Acceleration Velocity ENGINE\n","query = \"\"\"\n","WITH Loss_Acceleration AS(\n","SELECT\n","grade,\n","\n","    -- 1. 36-Month Horizon Performance Columns\n","    ROUND(\n","        SUM(CASE WHEN term = ' 36 months' AND loan_status = 'Charged Off' THEN loan_amnt ELSE 0 END) * 100.0 /\n","        NULLIF(SUM(CASE WHEN term = ' 36 months' THEN loan_amnt ELSE 0 END), 0),\n","        2\n","    ) as par_36_months_percent,\n","\n","    -- 2. 60-Month Horizon Performance Columns\n","    ROUND(\n","        SUM(CASE WHEN term = ' 60 months' AND loan_status = 'Charged Off' THEN loan_amnt ELSE 0 END) * 100.0 /\n","        NULLIF(SUM(CASE WHEN term = ' 60 months' THEN loan_amnt ELSE 0 END), 0),\n","        2\n","    ) as par_60_months_percent\n","FROM loans_ledger\n","WHERE loan_status IN('Fully Paid', 'Charged Off')AND grade IS NOT NULL\n","GROUP BY grade\n",")\n","SELECT\n","grade,\n","par_36_months_percent,\n","par_60_months_percent,\n","ROUND((par_60_months_percent/par_36_months_percent),2)AS Loss_Acceleration_Velocity\n","FROM Loss_Acceleration\n","GROUP BY grade\n","ORDER BY grade ASC;\n","\"\"\"\n","\n","# Execute the pure SQL query\n","df_sql_lav = pd.read_sql_query(query, conn)\n","\n","# Apply standard formatting preferences\n","pd.options.display.float_format = '{:,.2f}'.format\n","\n","# Output the unified matrix\n","df_sql_lav"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"QjPY29gNBaN3"},"outputs":[],"source":["#LIQUIDITY DEMANDS & DEBT-TO-INCOME (DTI) LEVERAGE ENGINE\n","query = \"\"\"\n","WITH Leverage_Base_Metrics AS (\n","    SELECT\n","        -- 1. Create Distinct Financial Leverage Brackets\n","        CASE\n","            WHEN dti < 10.0 THEN '1. Low Leverage (<10% DTI)'\n","            WHEN dti >= 10.0 AND dti < 20.0 THEN '2. Moderate Leverage (10-20% DTI)'\n","            WHEN dti >= 20.0 AND dti < 30.0 THEN '3. High Leverage (20-30% DTI)'\n","            ELSE '4. Severe Leverage Stress (30%+ DTI)'\n","        END as debt_leverage_band,\n","\n","        COUNT(*) as total_loans_issued,\n","        CAST(AVG(annual_inc) AS INT) as average_borrower_income,\n","        CAST(AVG(loan_amnt) AS INT) as average_loan_size,\n","        CAST(SUM(loan_amnt) AS INT) as total_capital_exposed,\n","\n","        -- Calculate the core Portfolio at Risk (PAR %) for this specific tier\n","        ROUND(\n","            SUM(CASE WHEN loan_status = 'Charged Off' THEN loan_amnt ELSE 0 END) * 100.0 / SUM(loan_amnt),\n","            2\n","        ) as portfolio_at_risk_percent\n","\n","    FROM loans_ledger\n","    WHERE loan_status IN ('Fully Paid', 'Charged Off')\n","      AND dti IS NOT NULL\n","      AND dti <= 60.0 -- Structural filter to drop extreme statistical data anomalies\n","    GROUP BY 1\n",")\n","SELECT\n","    debt_leverage_band,\n","    total_loans_issued,\n","    average_borrower_income,\n","    average_loan_size,\n","    total_capital_exposed,\n","    portfolio_at_risk_percent,\n","\n","    -- 2. Dynamically Calculate Capital Impairment Velocity (CIV) Relative to Tier 1\n","    ROUND(\n","        portfolio_at_risk_percent / (\n","            SELECT portfolio_at_risk_percent\n","            FROM Leverage_Base_Metrics\n","            WHERE debt_leverage_band = '1. Low Leverage (<10% DTI)'\n","        ),\n","        2\n","    ) as capital_impairment_velocity_civ\n","\n","FROM Leverage_Base_Metrics\n","ORDER BY debt_leverage_band ASC;\n","\"\"\"\n","\n","# Execute the leverage matrix query\n","df_dti_leverage = pd.read_sql_query(query, conn)\n","df_dti_leverage"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"35TwqMIihA7S"},"outputs":[],"source":["#CAPITAL RECOVERY & LOSS GIVEN DEFAULT (LGD) ENGINE\n","query = \"\"\"\n","SELECT\n","    grade,\n","\n","    -- 1. Baseline Default Counts\n","    COUNT(*) as total_default_cases,\n","\n","    -- 2. Aggregate Principal Exposed vs Cash Recovered\n","    CAST(SUM(loan_amnt) AS INT) as gross_capital_charged_off,\n","    CAST(SUM(recoveries) AS INT) as total_cash_recovered,\n","\n","    -- 3. Actuarial Recovery Rate Performance\n","    ROUND(\n","        SUM(recoveries) * 100.0 / SUM(loan_amnt),\n","        2\n","    ) as portfolio_recovery_rate_percent,\n","\n","    -- 4. Loss Given Default (LGD %) Calculation\n","    ROUND(\n","        100.0 - (SUM(recoveries) * 100.0 / SUM(loan_amnt)),\n","        2\n","    ) as loss_given_default_lgd_percent\n","\n","FROM loans_ledger\n","WHERE loan_status = 'Charged Off' -- Strict operational filter to isolate defaults\n","  AND grade IS NOT NULL\n","GROUP BY grade\n","ORDER BY grade ASC;\n","\"\"\"\n","\n","# Execute the capital recovery query\n","df_capital_recovery = pd.read_sql_query(query, conn)\n","\n","# Apply standard formatting preferences\n","pd.options.display.float_format = '{:,.2f}'.format\n","\n","# Output the matrix\n","df_capital_recovery"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"FUirTahEa1N8"},"outputs":[],"source":["#FICO × DTI RISK INTERACTION MULTIPLIER (RIM) ENGINE\n","query = \"\"\"\n","WITH Risk_Grid_Base AS (\n","    SELECT\n","        -- 1.FICO Stratification\n","        CASE\n","            WHEN fico_range_low >= 780 THEN '1. 780+ (Super Prime)'\n","            WHEN fico_range_low >= 720 AND fico_range_low < 780 THEN '2. 720-779 (Prime)'\n","            WHEN fico_range_low >= 660 AND fico_range_low < 720 THEN '3. 660-719 (Near Prime)'\n","            WHEN fico_range_low >= 600 AND fico_range_low < 660 THEN '4. 600-659 (Subprime)'\n","            ELSE '5. Below 600 (Deep Subprime)'\n","        END as fico_risk_band,\n","\n","        -- 2.Debt Leverage Stratification\n","        CASE\n","            WHEN dti < 10.0 THEN '1. Low Leverage (<10% DTI)'\n","            WHEN dti >= 10.0 AND dti < 20.0 THEN '2. Moderate Leverage (10-20% DTI)'\n","            WHEN dti >= 20.0 AND dti < 30.0 THEN '3. High Leverage (20-30% DTI)'\n","            ELSE '4. Severe Leverage Stress (30%+ DTI)'\n","        END as leverage_tier,\n","        AVG(dti)AS avg_dti,\n","\n","        COUNT(*) as total_loans_issued,\n","        CAST(SUM(loan_amnt) AS INT) as total_capital_exposed,\n","\n","        -- Cell Performance Metric (PAR %)\n","        ROUND(\n","            SUM(CASE WHEN loan_status = 'Charged Off' THEN loan_amnt ELSE 0 END) * 100.0 / SUM(loan_amnt),\n","            2\n","        ) as cell_portfolio_at_risk_percent\n","\n","    FROM loans_ledger\n","    WHERE loan_status IN ('Fully Paid', 'Charged Off')\n","      AND fico_range_low IS NOT NULL\n","      AND dti IS NOT NULL\n","      AND dti <= 60.0\n","    GROUP BY 1, 2\n",")\n","SELECT\n","    fico_risk_band,\n","    leverage_tier,\n","    avg_dti,\n","    total_loans_issued,\n","    total_capital_exposed,\n","    cell_portfolio_at_risk_percent,\n","\n","    -- 3. Calculate the Risk Interaction Multiplier (RIM) relative to the Control Cell\n","    ROUND(\n","        cell_portfolio_at_risk_percent*avg_dti / NULLIF((\n","            SELECT (cell_portfolio_at_risk_percent*avg_dti)\n","            FROM Risk_Grid_Base\n","            WHERE fico_risk_band = '1. 780+ (Super Prime)'\n","              AND leverage_tier = '1. Low Leverage (<10% DTI)'\n","        ), 0),\n","        2\n","    ) as risk_interaction_multiplier_rim\n","\n","FROM Risk_Grid_Base\n","ORDER BY fico_risk_band ASC, leverage_tier ASC;\n","\"\"\"\n","\n","# Execute the multi-dimensional RIM query\n","df_rim_matrix = pd.read_sql_query(query, conn)\n","\n","# Apply standard formatting preferences\n","pd.options.display.float_format = '{:,.2f}'.format\n","\n","# Output the matrix with the standalone RIM column\n","df_rim_matrix"]},{"cell_type":"code","source":["import matplotlib.pyplot as plt\n","import seaborn as sns\n","import pandas as pd\n","import numpy as np\n","\n","# Set uniform corporate presentation configurations\n","sns.set_theme(style=\"whitegrid\")\n","plt.rcParams.update({\n","    'font.size': 9,\n","    'axes.labelsize': 11,\n","    'axes.titlesize': 12,\n","    'xtick.labelsize': 9,\n","    'ytick.labelsize': 9,\n","    'figure.titlesize': 22\n","})\n","\n","# Initialize an expanded 6-Row, 2-Column Grid Canvas Layout (12 Charts Total)\n","fig, axes = plt.subplots(6, 2, figsize=(22, 42))\n","plt.suptitle(\"Credit Portfolio Risk Modeling \",\n","             fontweight='bold', y=0.98)\n","\n","# =====================================================================\n","# CHART 1: TOTAL CAPITAL DEPLOYED BY RISK GRADE\n","# =====================================================================\n","q1 = \"\"\"\n","SELECT grade, SUM(loan_amnt) as total_capital\n","FROM loans_ledger\n","WHERE loan_status IN ('Fully Paid','Charged Off') AND grade IS NOT NULL\n","GROUP BY 1 ORDER BY 1;\n","\"\"\"\n","df1 = pd.read_sql_query(q1, conn)\n","sns.barplot(ax=axes[0,0], x='grade', y='total_capital', data=df1, palette='Blues_r')\n","axes[0,0].set_title(\"Total Capital Deployed Portfolio Distribution\", fontweight='bold')\n","axes[0,0].set_xlabel(\"Loan Grade Tier\")\n","axes[0,0].set_ylabel(\"Total Capital Deployed ($)\")\n","axes[0,0].get_yaxis().set_major_formatter(plt.FuncFormatter(lambda x, loc: f\"${int(x):,}\"))\n","for p in axes[0,0].patches:\n","    axes[0,0].annotate(f\"${int(p.get_height()):,}\", (p.get_x() + p.get_width() / 2., p.get_height()),\n","                ha='center', va='bottom', xytext=(0, 3), textcoords='offset points', fontweight='bold', color='#2c3e50')\n","\n","# =====================================================================\n","# CHART 2: AVERAGE PRICING YIELD PROFILE BY GRADE\n","# =====================================================================\n","q2 = \"SELECT grade, ROUND(AVG(int_rate), 2) as avg_yield FROM loans_ledger WHERE grade IS NOT NULL GROUP BY 1 ORDER BY 1;\"\n","df2 = pd.read_sql_query(q2, conn)\n","sns.lineplot(ax=axes[0,1], x='grade', y='avg_yield', data=df2, marker='s', color='#2c3e50', linewidth=3, markersize=8)\n","axes[0,1].set_title(\"Average Pricing Yield Profile by Grade\", fontweight='bold')\n","axes[0,1].set_xlabel(\"Loan Grade Tier\")\n","axes[0,1].set_ylabel(\"Nominal Interest Rate (%)\")\n","for i, txt in enumerate(df2['avg_yield']):\n","    axes[0,1].annotate(f\"{txt:.2f}%\", (df2['grade'].iloc[i], df2['avg_yield'].iloc[i]), textcoords=\"offset points\", xytext=(0,10), ha='center', fontweight='bold', color='#2c3e50')\n","\n","# =====================================================================\n","# CHART 3: REALIZED VOLUME-WEIGHTED PORTFOLIO AT RISK (PAR %)\n","# =====================================================================\n","q3 = \"\"\"\n","SELECT\n","    CASE\n","        WHEN fico_range_low >= 780 THEN 'Super Prime' WHEN fico_range_low >= 720 THEN 'Prime'\n","        WHEN fico_range_low >= 660 THEN 'Near Prime' WHEN fico_range_low >= 600 THEN 'Subprime'\n","        ELSE 'Deep Subprime' END as tier,\n","    ROUND(SUM(CASE WHEN loan_status='Charged Off' THEN loan_amnt ELSE 0 END)*100.0/SUM(loan_amnt),2) as volume_weighted_par\n","FROM loans_ledger WHERE loan_status IN ('Fully Paid','Charged Off') AND fico_range_low IS NOT NULL GROUP BY 1\n","ORDER BY tier\n","\"\"\"\n","df3 = pd.read_sql_query(q3, conn)\n","axes[1,0].plot(df3['tier'], df3['volume_weighted_par'], marker='o', color='#c0392b', linewidth=3, markersize=8)\n","axes[1,0].fill_between(df3['tier'], df3['volume_weighted_par'], color='#c0392b', alpha=0.12)\n","axes[1,0].set_title(\"Realized Volume-Weighted Portfolio at Risk (PAR %)\", fontweight='bold')\n","axes[1,0].set_xlabel(\"Credit Risk Classification Tiers\")\n","axes[1,0].set_ylabel(\"Realized Capital Loss Velocity (PAR %)\")\n","for i, txt in enumerate(df3['volume_weighted_par']):\n","    axes[1,0].annotate(f\"{txt:.2f}%\", (df3['tier'].iloc[i], df3['volume_weighted_par'].iloc[i]), textcoords=\"offset points\", xytext=(0,10), ha='center', fontweight='bold', color='#c0392b')\n","\n","# =====================================================================\n","# CHART 4: LOSS ACCELERATION VELOCITY (LAV) SHIFT MULTIPLIER\n","# =====================================================================\n","q4 = \"\"\"\n","WITH Horizon_PAR AS (\n","    SELECT\n","        grade,\n","        SUM(CASE WHEN term LIKE '%36%' THEN loan_amnt ELSE 0 END) as total_36_capital,\n","        SUM(CASE WHEN term LIKE '%36%' AND loan_status='Charged Off' THEN loan_amnt ELSE 0 END) as default_36_capital,\n","        SUM(CASE WHEN term LIKE '%60%' THEN loan_amnt ELSE 0 END) as total_60_capital,\n","        SUM(CASE WHEN term LIKE '%60%' AND loan_status='Charged Off' THEN loan_amnt ELSE 0 END) as default_60_capital\n","    FROM loans_ledger\n","    WHERE loan_status IN ('Fully Paid','Charged Off') AND grade IS NOT NULL\n","    GROUP BY 1\n",")\n","SELECT\n","    grade,\n","    ROUND(\n","        (default_60_capital * 100.0 / NULLIF(total_60_capital, 0)) /\n","        NULLIF((default_36_capital * 100.0 / NULLIF(total_36_capital, 0)), 0),\n","        2\n","    ) as lav_multiplier\n","FROM Horizon_PAR\n","ORDER BY grade ASC;\n","\"\"\"\n","df4 = pd.read_sql_query(q4, conn).dropna()\n","sns.lineplot(ax=axes[1,1], x='grade', y='lav_multiplier', data=df4, marker='D', color='#1f77b4', linewidth=3, markersize=8)\n","axes[1,1].axhline(1.00, color='red', linestyle='--', linewidth=1.5, label='Parity Baseline (1.00x)')\n","axes[1,1].set_title(\"Loss Acceleration Velocity (LAV) Horizon Multiplier By Grade\", fontweight='bold')\n","axes[1,1].set_xlabel(\"Underwriting Loan Grade\")\n","axes[1,1].set_ylabel(\"LAV Index Factor (60M PAR% / 36M PAR%)\")\n","axes[1,1].legend(loc=\"upper left\")\n","for i, txt in enumerate(df4['lav_multiplier']):\n","    axes[1,1].annotate(f\"{txt:.2f}x\", (df4['grade'].iloc[i], df4['lav_multiplier'].iloc[i]), textcoords=\"offset points\", xytext=(0,10), ha='center', fontweight='bold', color='#1f77b4')\n","\n","# =====================================================================\n","# CHART 5: HORIZON RISK SPREAD SPECTRUM\n","# =====================================================================\n","q5 = \"\"\"\n","SELECT grade, term, ROUND(SUM(CASE WHEN loan_status='Charged Off' THEN loan_amnt ELSE 0 END)*100.0/SUM(loan_amnt),2) as volume_weighted_par\n","FROM loans_ledger WHERE loan_status IN ('Fully Paid','Charged Off') AND grade IS NOT NULL GROUP BY 1, 2 ORDER BY 1, 2;\n","\"\"\"\n","df5 = pd.read_sql_query(q5, conn)\n","sns.barplot(ax=axes[2,0], x='grade', y='volume_weighted_par', hue='term', data=df5, palette='coolwarm')\n","axes[2,0].set_title(\"Horizon Risk Spread (Volume-Weighted PAR % by Duration)\", fontweight='bold')\n","axes[2,0].set_xlabel(\"Loan Grade Tier\")\n","axes[2,0].set_ylabel(\"Realized Capital at Risk (PAR %)\")\n","axes[2,0].legend(title=\"Contract Horizon\")\n","\n","# =====================================================================\n","# CHART 6: CAPITAL IMPAIRMENT VELOCITY (CIV) CONTROL ENGINE\n","# =====================================================================\n","q6 = \"\"\"\n","WITH Leverage_Metrics AS (\n","    SELECT\n","        CASE\n","            WHEN dti < 10.0 THEN 'Low Leverage (<10%)'\n","            WHEN dti >= 10.0 AND dti < 20.0 THEN 'Moderate Leverage (10-20%)'\n","            WHEN dti >= 20.0 AND dti < 30.0 THEN 'High Leverage (20-30%)'\n","            ELSE 'Severe Stress (30%+)'\n","        END as leverage_tier,\n","        SUM(loan_amnt) as total_capital,\n","        SUM(CASE WHEN loan_status = 'Charged Off' THEN loan_amnt ELSE 0 END) as default_capital\n","    FROM loans_ledger\n","    WHERE loan_status IN ('Fully Paid', 'Charged Off') AND dti <= 60.0\n","    GROUP BY 1\n","),\n","Calculated_PAR AS (\n","    SELECT\n","        leverage_tier,\n","        (default_capital * 100.0 / total_capital) as tier_par\n","    FROM Leverage_Metrics\n",")\n","SELECT\n","    leverage_tier,\n","    ROUND(tier_par / (SELECT tier_par FROM Calculated_PAR WHERE leverage_tier = 'Low Leverage (<10%)'), 2) as civ_index\n","FROM Calculated_PAR\n","ORDER BY CASE\n","    WHEN leverage_tier = 'Low Leverage (<10%)' THEN 1\n","    WHEN leverage_tier = 'Moderate Leverage (10-20%)' THEN 2\n","    WHEN leverage_tier = 'High Leverage (20-30%)' THEN 3\n","    ELSE 4 END;\n","\"\"\"\n","df6 = pd.read_sql_query(q6, conn)\n","axes[2,1].plot(df6['leverage_tier'], df6['civ_index'], marker='o', color='#e67e22', linewidth=3, markersize=8)\n","axes[2,1].fill_between(df6['leverage_tier'], df6['civ_index'], 1.00, color='#e67e22', alpha=0.10)\n","axes[2,1].axhline(1.00, color='red', linestyle='--', linewidth=1.5, label='Control Baseline (1.00x)')\n","axes[2,1].set_title(\"Capital Impairment Velocity (CIV) Relative Leverage Index\", fontweight='bold')\n","axes[2,1].set_xlabel(\"Debt-to-Income (DTI) Leverage Bands\")\n","axes[2,1].set_ylabel(\"CIV Index (Risk Ratio vs. Low Leverage Control)\")\n","axes[2,1].legend(loc=\"upper left\")\n","for i, txt in enumerate(df6['civ_index']):\n","    axes[2,1].annotate(f\"{txt:.2f}x\", (df6['leverage_tier'].iloc[i], df6['civ_index'].iloc[i]), textcoords=\"offset points\", xytext=(0,10), ha='center', fontweight='bold', color='#e67e22')\n","\n","# =====================================================================\n","# CHART 7: REGIONAL CAPITAL CONCENTRATION EXPOSURE — TOP 10 STATES\n","# =====================================================================\n","q7 = \"SELECT addr_state, SUM(loan_amnt) as exposure FROM loans_ledger WHERE addr_state IS NOT NULL GROUP BY 1 ORDER BY exposure DESC LIMIT 10;\"\n","df7 = pd.read_sql_query(q7, conn)\n","sns.barplot(ax=axes[3,0], x='exposure', y='addr_state', data=df7, palette='flare_r')\n","axes[3,0].set_title(\"Regional Capital Concentration Exposure — Top 10 States\", fontweight='bold')\n","axes[3,0].set_xlabel(\"Total Capital Exposed ($)\")\n","axes[3,0].set_ylabel(\"Operational States\")\n","axes[3,0].get_xaxis().set_major_formatter(plt.FuncFormatter(lambda x, loc: f\"${int(x):,}\"))\n","\n","# =====================================================================\n","# CHART 8: LOSS GIVEN DEFAULT (LGD %) CAPITAL WIPEOUT PROFILE\n","# =====================================================================\n","q8 = \"SELECT grade, ROUND(100.0 - (SUM(recoveries)*100.0/SUM(loan_amnt)), 2) as realized_lgd FROM loans_ledger WHERE loan_status='Charged Off' AND grade IS NOT NULL GROUP BY 1 ORDER BY 1;\"\n","df8 = pd.read_sql_query(q8, conn)\n","sns.barplot(ax=axes[3,1], x='grade', y='realized_lgd', data=df8, palette='dark:salmon_r')\n","axes[3,1].set_title(\"Loss Given Default (LGD %) Post-Default Write-Off Severity\", fontweight='bold')\n","axes[3,1].set_xlabel(\"Underwriting Asset Risk Grade\")\n","axes[3,1].set_ylabel(\"Realized LGD (Net Loss % Per Default)\")\n","axes[3,1].set_ylim(0, 105)\n","for p in axes[3,1].patches:\n","    axes[3,1].annotate(f\"{p.get_height():.2f}%\", (p.get_x() + p.get_width() / 2., p.get_height()),\n","                ha='center', va='bottom', xytext=(0, 5), textcoords='offset points', fontweight='bold', color='#c0392b')\n","\n","# =====================================================================\n","# CHART 9: LEVERAGE-WEIGHTED RISK INTERACTION MULTIPLIER (RIM) MATRIX\n","# =====================================================================\n","q9 = \"\"\"\n","WITH Risk_Grid_Base AS (\n","    SELECT\n","        CASE\n","            WHEN fico_range_low >= 780 THEN '1. Super Prime (780+)'\n","            WHEN fico_range_low >= 720 AND fico_range_low < 780 THEN '2. Prime (720-779)'\n","            WHEN fico_range_low >= 660 AND fico_range_low < 720 THEN '3. Near Prime (660-719)'\n","            WHEN fico_range_low >= 600 AND fico_range_low < 660 THEN '4. Subprime (600-659)'\n","            ELSE '5. Below 600 (Deep Subprime)'\n","        END as fico_risk_band,\n","        CASE\n","            WHEN dti < 10.0 THEN '1. Low Leverage (<10%)'\n","            WHEN dti >= 10.0 AND dti < 20.0 THEN '2. Moderate Leverage (10-20%)'\n","            WHEN dti >= 20.0 AND dti < 30.0 THEN '3. High Leverage (20-30%)'\n","            ELSE '4. Severe Stress (30%+)'\n","        END as leverage_tier,\n","        ROUND(SUM(CASE WHEN loan_status = 'Charged Off' THEN loan_amnt ELSE 0 END) * 100.0 / SUM(loan_amnt), 2) as cell_par,\n","        AVG(dti) as cell_average_dti\n","    FROM loans_ledger\n","    WHERE loan_status IN ('Fully Paid', 'Charged Off')\n","      AND fico_range_low IS NOT NULL\n","      AND dti IS NOT NULL\n","      AND dti <= 60.0\n","    GROUP BY 1, 2\n",")\n","SELECT fico_risk_band, leverage_tier, cell_average_dti, cell_par,\n","       ROUND((cell_par * cell_average_dti) / NULLIF((\n","    SELECT (cell_par*cell_average_dti) FROM Risk_Grid_Base WHERE fico_risk_band = '1. Super Prime (780+)' AND leverage_tier = '1. Low Leverage (<10%)'\n","), 0), 2) as weighted_rim FROM Risk_Grid_Base;\n","\"\"\"\n","df9 = pd.read_sql_query(q9, conn)\n","fico_order = ['1. Super Prime (780+)', '2. Prime (720-779)', '3. Near Prime (660-719)', '4. Subprime (600-659)', '5. Below 600 (Deep Subprime)']\n","dti_order = ['1. Low Leverage (<10%)', '2. Moderate Leverage (10-20%)', '3. High Leverage (20-30%)', '4. Severe Stress (30%+)']\n","df_pivot_rim = df9.pivot(index='fico_risk_band', columns='leverage_tier', values='weighted_rim').reindex(index=fico_order, columns=dti_order).fillna(0)\n","\n","sns.heatmap(ax=axes[4,0], data=df_pivot_rim, annot=True, fmt=\".2f\", cmap=\"RdYlGn_r\", linewidths=1.2, cbar=True, annot_kws={\"weight\": \"bold\", \"size\": 10})\n","axes[4,0].set_title(\"Leverage-Weighted Risk Interaction Multiplier (RIM) Matrix\", fontweight='bold')\n","axes[4,0].set_xlabel(\"DTI Leverage Tiers\")\n","axes[4,0].set_ylabel(\"FICO Credit Risk Bands\")\n","\n","# =====================================================================\n","# CHART 10: NEW MULTI-LINE CONTINUOUS RIM CURVES\n","# =====================================================================\n","# Using the clean df9 framework generated above to plot continuous trajectories\n","sns.lineplot(\n","    ax=axes[4,1],\n","    data=df9,\n","    x='leverage_tier',\n","    y='weighted_rim',\n","    hue='fico_risk_band',\n","    hue_order=fico_order,\n","    marker='o',\n","    linewidth=3,\n","    markersize=8,\n","    palette='Spectral_r'\n",")\n","axes[4,1].axhline(1.00, color='black', linestyle='--', linewidth=1.5, label='Control Baseline (1.00x)')\n","axes[4,1].set_title(\"Continuous RIM Stress Curves Across Leverage Horizons\", fontweight='bold')\n","axes[4,1].set_xlabel(\"Debt-to-Income (DTI) Leverage Tiers\")\n","axes[4,1].set_ylabel(\"RIM Index Factor (Relative Multiplier)\")\n","axes[4,1].legend(title=\"FICO Credit Risk Bands\", loc='upper left', frameon=True)\n","axes[4,1].tick_params(axis='x', rotation=15)\n","\n","# =====================================================================\n","# CHART 11: EMPTY PLACEHOLDER / DENSITY OVERVIEW (Balances Grid Symmetry)\n","# =====================================================================\n","# Plotting raw volume density per FICO band to justify risk curves\n","df_fico_counts = df9.groupby('fico_risk_band')['weighted_rim'].mean().reset_index()\n","sns.barplot(ax=axes[5,0], x='weighted_rim', y='fico_risk_band', data=df_fico_counts, palette='magma', order=fico_order)\n","axes[5,0].set_title(\"Mean Risk Multiplier Profile by Underwriting Band\", fontweight='bold')\n","axes[5,0].set_xlabel(\"Average Compounded RIM Factor\")\n","axes[5,0].set_ylabel(\"FICO Credit Risk Bands\")\n","\n","# =====================================================================\n","# CHART 12: CHRONOLOGICAL CREDIT DRIFT ACCELERATION (CDA) TIMELINE\n","# =====================================================================\n","q12 = \"\"\"\n","SELECT\n","    CASE\n","        WHEN issue_d LIKE '%-2007' THEN '2007' WHEN issue_d LIKE '%-2008' THEN '2008'\n","        WHEN issue_d LIKE '%-2009' THEN '2009' WHEN issue_d LIKE '%-2010' THEN '2010'\n","        WHEN issue_d LIKE '%-2011' THEN '2011' WHEN issue_d LIKE '%-2012' THEN '2012'\n","        WHEN issue_d LIKE '%-2013' THEN '2013' WHEN issue_d LIKE '%-2014' THEN '2014'\n","        WHEN issue_d LIKE '%-2015' THEN '2015' WHEN issue_d LIKE '%-2016' THEN '2016'\n","        WHEN issue_d LIKE '%-2017' THEN '2017' WHEN issue_d LIKE '%-2018' THEN '2018'\n","        ELSE 'Other' END as yr,\n","    ROUND(SUM(CASE WHEN loan_status = 'Charged Off' THEN loan_amnt ELSE 0 END) * 100.0 / SUM(loan_amnt), 2) as vintage_par\n","FROM loans_ledger WHERE loan_status IN ('Fully Paid', 'Charged Off') AND issue_d IS NOT NULL GROUP BY 1 HAVING yr <> 'Other' ORDER BY yr ASC;\n","\"\"\"\n","df12 = pd.read_sql_query(q12, conn)\n","df12['cda_ratio'] = df12['vintage_par'] / df12['vintage_par'].shift(1)\n","df12_clean = df12.dropna()\n","\n","sns.lineplot(ax=axes[5,1], x='yr', y='cda_ratio', data=df12_clean, marker='D', color='#8e44ad', linewidth=3, markersize=8)\n","axes[5,1].axhline(1.00, color='red', linestyle='--', linewidth=1.5, label='Stability Baseline (1.00x)')\n","axes[5,1].set_title(\"Credit Drift Acceleration (CDA) Velocity Timeline\", fontweight='bold')\n","axes[5,1].set_xlabel(\"Chronological Origination Vintage Year\")\n","axes[5,1].set_ylabel(\"CDA Acceleration Factor Ratio\")\n","axes[5,1].legend(loc=\"upper left\")\n","for i, txt in enumerate(df12_clean['cda_ratio']):\n","    axes[5,1].annotate(f\"{txt:.2f}x\", (df12_clean['yr'].iloc[i], df12_clean['cda_ratio'].iloc[i]), textcoords=\"offset points\", xytext=(0,10), ha='center', fontweight='bold', color='#8e44ad')\n","\n","# Structural layout optimization and clean canvas margin adjustments\n","plt.tight_layout(rect=[0, 0, 1, 0.96])\n","fig.savefig('volume_weighted_baseline_dashboard.png', dpi=300, bbox_inches='tight')\n","plt.show()"],"metadata":{"id":"cfy1j1V4na7I"},"execution_count":null,"outputs":[]}],"metadata":{"colab":{"provenance":[{"file_id":"1-aVrtkyrRh5Bj05CC_TsddTlG7R7IeF5","timestamp":1782660064852}],"authorship_tag":"ABX9TyNRFUChWsk51Qu0naT36UzF"},"kernelspec":{"display_name":"Python 3","name":"python3"},"language_info":{"name":"python"}},"nbformat":4,"nbformat_minor":0}